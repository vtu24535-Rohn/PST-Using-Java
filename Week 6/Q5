import java.util.*;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.next();

        int count = 0;

        for (int i = 0; i < s.length(); i++) {
            if (i % 3 == 0 || i % 3 == 2) {
                if (s.charAt(i) != 'S') count++;
            } else {
                if (s.charAt(i) != 'O') count++;
            }
        }

        System.out.println(count);
    }
}